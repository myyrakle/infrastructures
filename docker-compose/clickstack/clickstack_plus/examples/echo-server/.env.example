# Copy this file to .env and paste the Ingestion API Key from HyperDX Team Settings.
CLICKSTACK_INGESTION_API_KEY=

# Optional overrides.
OTEL_EXPORTER_OTLP_ENDPOINT=https://clickhouse-otel-exporter.chainshift.co
ECHO_SERVER_PORT=18081
DATABASE_URL=postgres://${USER:-postgres}@host.docker.internal:5432/postgres?sslmode=disable
