# ClickStack all-in-one image tag
CLICKSTACK_IMAGE=clickhouse/clickstack-all-in-one:2.29.0

# Host port mappings
HYPERDX_PORT=8080
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# ClickHouse users
CLICKHOUSE_DEFAULT_PASSWORD=...
CLICKHOUSE_API_PASSWORD=...
CLICKHOUSE_WORKER_PASSWORD=...

# External origin users reach the HyperDX UI on (scheme://host:port).
# Used as the absolute base for post-login redirects. Set this to the
# tunnel/proxy/public URL — NOT localhost — or login redirects will break.
FRONTEND_URL=https://hyperdx.???.com
