# --- otel-rds-collector (RDS PostgreSQL 메트릭 수집) ---
# 사전 준비(모니터링 유저 SQL, RDS SG, CA 번들)는 otel-rds-collector/README.md 참고
# 메트릭을 보낼 수신 콜렉터의 OTLP HTTP 주소(스킴 포함 URL). 비우면 같은 compose
# 네트워크의 http://clickstack-otel-collector:4318 로 보낸다.
# 외부 주소는 OTLP HTTP(4318)로 연결되는 프록시여야 한다 (gRPC 4317 아님).
OTEL_COLLECTOR_ENDPOINT=https://clickhouse-otel-exporter.?:443
# HyperDX Team Settings > API Keys 의 Ingestion API Key (raw 토큰, Bearer 없음)
CLICKSTACK_INGESTION_API_KEY="?"

# 호스트는 포트 없이 지정 (포트는 POSTGRES_*_PORT, 기본 5432)
POSTGRES_DEV_HOST=dev-?.ap-northeast-2.rds.amazonaws.com
POSTGRES_DEV_DATABASE=?
POSTGRES_DEV_MONITOR_USER=otel_monitor
POSTGRES_DEV_MONITOR_PASSWORD='?'
POSTGRES_PROD_HOST=prod-?.ap-northeast-2.rds.amazonaws.com
POSTGRES_PROD_DATABASE=?
POSTGRES_PROD_MONITOR_USER=otel_monitor
POSTGRES_PROD_MONITOR_PASSWORD='?'

# CloudWatch(AWS/RDS) 인스턴스 지표용 IAM 키 — dev/prod 는 AWS 계정이 달라 2세트.
# 각 계정의 IAM 유저 키 (최소 권한: cloudwatch:GetMetricData, ListMetrics).
# 비워 두면 CloudWatch 수집만 매 주기 인증 에러 로그를 남기고 나머지는 정상 동작.
AWS_DEV_ACCESS_KEY_ID="?"
AWS_DEV_SECRET_ACCESS_KEY="?"
AWS_PROD_ACCESS_KEY_ID="?"
AWS_PROD_SECRET_ACCESS_KEY="?"
